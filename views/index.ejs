  <!-- HERO -->
  <section class="hero" id="home">
    <div class="hero__bg">
      <div class="hero__blob blob-1"></div>
      <div class="hero__blob blob-2"></div>
      <div class="hero__grid"></div>
    </div>

    <div class="hero__content">
      <div class="hero__text">
        <p class="hero__eyebrow reveal-up">Marketing Leader & Content Creator</p>
        <h1 class="hero__name reveal-up">
          Trần<br /><em>Hồng Sơn</em>
        </h1>
        <p class="hero__desc reveal-up">
          5 năm kinh nghiệm xây dựng thương hiệu, tối ưu hiệu suất quảng cáo và sản xuất nội dung đa nền tảng.
        </p>
        <div class="hero__tags reveal-up">
          <span>Branding</span>
          <span>Performance Ads</span>
          <span>Design</span>
          <span>Video</span>
        </div>
        <div class="hero__cta reveal-up">
          <a href="#projects" class="btn btn--primary">Xem dự án</a>
          <a href="#contact" class="btn btn--ghost">Liên hệ</a>
        </div>
      </div>

      <div class="hero__avatar-wrap">
        <div class="hero__avatar-ring"></div>
        <div class="hero__avatar-glow"></div>
        <img
          src="/images/avatar/avatar.jpg"
          alt="Trần Hồng Sơn"
          class="hero__avatar reveal-scale"
          id="heroAvatar"
        />
        <div class="hero__avatar-badge">
          <span class="badge__num">5+</span>
          <span class="badge__text">Năm kinh nghiệm</span>
        </div>
      </div>
    </div>

    <div class="hero__scroll-hint">
      <span>Scroll</span>
      <div class="scroll-line"></div>
    </div>
  </section>

  <!-- ABOUT -->
  <section class="about section" id="about">
    <div class="container">
      <div class="section-label reveal-up">01 — Giới thiệu</div>
      <div class="about__grid">
        <div class="about__left reveal-up">
          <h2 class="section-title">Marketer đa nhiệm,<br /><em>kết quả thực chiến</em></h2>
          <p class="about__text">
            Tôi là Trần Hồng Sơn, một Marketing Leader với nền tảng vững chắc từ Digital Marketing, Brand Strategy đến Video Production. Tôi không chỉ lên kế hoạch — tôi thực thi từ concept đến kết quả đo lường được.
          </p>
          <p class="about__text">
            Với kinh nghiệm quản lý ngân sách quảng cáo lên tới <strong>800 triệu/tháng</strong>, tôi hiểu cách mỗi đồng chi phí tạo ra giá trị thực sự cho doanh nghiệp.
          </p>
          <div class="about__stats">
            <div class="stat-card">
              <span class="stat-num" data-target="5">0</span><span>+</span>
              <span class="stat-label">Năm kinh nghiệm</span>
            </div>
            <div class="stat-card">
              <span class="stat-num" data-target="4">0</span>
              <span class="stat-label">Công ty đã làm việc</span>
            </div>
            <div class="stat-card">
              <span class="stat-num" data-target="800">0</span><span>M+</span>
              <span class="stat-label">KPI/tháng đạt được</span>
            </div>
          </div>
        </div>
        <div class="about__right reveal-right">
          <div class="info-card">
            <div class="info-row">
              <svg viewBox="0 0 24 24"><path d="M6.62 10.79c1.44 2.83 3.76 5.14 6.59 6.59l2.2-2.2c.27-.27.67-.36 1.02-.24 1.12.37 2.33.57 3.57.57.55 0 1 .45 1 1V20c0 .55-.45 1-1 1-9.39 0-17-7.61-17-17 0-.55.45-1 1-1h3.5c.55 0 1 .45 1 1 0 1.25.2 2.45.57 3.57.11.35.03.74-.25 1.02l-2.2 2.2z"/></svg>
              <span>0987 603 615</span>
            </div>
            <div class="info-row">
              <svg viewBox="0 0 24 24"><path d="M20 4H4c-1.1 0-2 .9-2 2v12c0 1.1.9 2 2 2h16c1.1 0 2-.9 2-2V6c0-1.1-.9-2-2-2zm0 4l-8 5-8-5V6l8 5 8-5v2z"/></svg>
              <span>decaztran@gmail.com</span>
            </div>
            <div class="info-row">
              <svg viewBox="0 0 24 24"><path d="M12 2C8.13 2 5 5.13 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.87-3.13-7-7-7zm0 9.5c-1.38 0-2.5-1.12-2.5-2.5s1.12-2.5 2.5-2.5 2.5 1.12 2.5 2.5-1.12 2.5-2.5 2.5z"/></svg>
              <span>KĐT Kỳ Bá, Tp. Thái Bình</span>
            </div>
            <div class="info-row">
              <svg viewBox="0 0 24 24"><path d="M12 2.04C6.5 2.04 2 6.53 2 12.06C2 17.06 5.66 21.21 10.44 21.96V14.96H7.9V12.06H10.44V9.85C10.44 7.34 11.93 5.96 14.22 5.96C15.31 5.96 16.45 6.15 16.45 6.15V8.62H15.19C13.95 8.62 13.56 9.39 13.56 10.18V12.06H16.34L15.89 14.96H13.56V21.96A10 10 0 0 0 22 12.06C22 6.53 17.5 2.04 12 2.04Z"/></svg>
              <a href="https://www.facebook.com/secaz.0410" target="_blank">facebook.com/secaz.0410</a>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

