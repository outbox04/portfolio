<!DOCTYPE html>
<html lang="vi" prefix="og: https://ogp.me/ns#">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />

  <!-- ═══ PRIMARY META ═══ -->
  <title>Trần Hồng Sơn — Marketing Portfolio</title>
  <meta name="description" content="Marketing Leader 5 năm kinh nghiệm | Branding · Performance Ads · Design · Video Production. KPI 800 triệu/tháng." />
  <meta name="author" content="Trần Hồng Sơn" />
  <meta name="keywords" content="Marketing, Digital Marketing, Branding, Facebook Ads, Content Creator, Video Production, Thái Bình" />
  <link rel="canonical" href="<%= siteUrl %>" />

  <!-- ═══ OPEN GRAPH (Facebook, Zalo, LinkedIn, Telegram) ═══ -->
  <meta property="og:type"         content="website" />
  <meta property="og:url"          content="<%= siteUrl %>" />
  <meta property="og:site_name"    content="Trần Hồng Sơn Portfolio" />
  <meta property="og:title"        content="Trần Hồng Sơn — Marketing Leader & Content Creator" />
